<?php
// ===== TIMEZONE E ENCODING =====
date_default_timezone_set("America/Sao_Paulo");
ini_set("default_charset", "UTF-8");
ini_set("post_max_size", "4096M");
ini_set("upload_max_filesize", "4096M");

// ===== BANCO DE DADOS =====
define("DB_HOST", "mysql");
define("DB_NAME", "<DB_NAME>");
define("DB_USER", "<DB_USER>");
define("DB_PASS", "<DB_PASS>");

// ===== REDIS =====
define("REDIS_HOST", "redis");
define("REDIS_PORT", 6379);
define("REDIS_PREFIX", "driftex:site:");
define("REDIS_DATABASE", 0);
define("REDIS_ENABLED", true);
define("REDIS_DEFAULT_TTL", 3600);

// ===== KAFKA =====
define("KAFKA_HOST", "kafka_broker");
define("KAFKA_PORT", "9092");
define("KAFKA_TOPIC_EMAIL", "driftex_site_emails");
define("KAFKA_CONSUMER_GROUP", "driftex-email-worker-group");

// ===== EMAIL (SMTP) =====
define("mail_from_name", "Driftex");
define("mail_from_mail", "noreply@<SEU_DOMINIO>");
define("mail_from_host", "smtp.gmail.com");
define("mail_from_port", "587");
define("mail_from_user", "<MAIL_USER>");
define("mail_from_pwd", "<MAIL_PASS>");

// ===== APLICAÇÃO =====
define("cAppKey", "driftex_site_session");
define("cTitle", "Driftex");
define("cAppRoot", "/");
define("cRootServer", sprintf("%s%s", $_SERVER["DOCUMENT_ROOT"], constant("cAppRoot")));
define("cRootServer_APP", sprintf("%s%s", $_SERVER["DOCUMENT_ROOT"], constant("cAppRoot") . "../app"));

// Detecta HTTPS mesmo atrás de reverse proxy (Traefik com SSL termination).
// O Apache propaga X-Forwarded-Proto via SetEnvIf, populando $_SERVER['HTTPS'].
$_detected_protocol = 'http';
if (
    (!empty($_SERVER['HTTPS']) && strtolower($_SERVER['HTTPS']) !== 'off') ||
    (!empty($_SERVER['HTTP_X_FORWARDED_PROTO']) && strtolower($_SERVER['HTTP_X_FORWARDED_PROTO']) === 'https') ||
    (!empty($_SERVER['SERVER_PORT']) && (int)$_SERVER['SERVER_PORT'] === 443)
) {
    $_detected_protocol = 'https';
}
define("cFrontend", sprintf("%s://%s%s", $_detected_protocol, $_SERVER["HTTP_HOST"] ?? "localhost", constant("cAppRoot")));
unset($_detected_protocol);
define("cAssets", sprintf("%s%s", constant("cFrontend"), "assets/"));

// ===== UPLOAD =====
define("UPLOAD_DIR", "/var/www/driftex/site/public_html/assets/upload/");
define("UPLOAD_MAX_SIZE", 10);
define("UPLOAD_ALLOWED_TYPES", "jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx");

// ===== SESSÃO =====
define("SESSION_LIFETIME", 7200);
define("SESSION_USE_REDIS", false);

// ===== KEYS =====
define("binanceAPIKey", "<BINANCE_API_KEY>");
define("binanceSecretKey", "<BINANCE_API_SECRET>");

// ===== INICIALIZAR REDIS =====
if (REDIS_ENABLED && class_exists("RedisCache")) {
    try {
        $GLOBALS["redis"] = RedisCache::getInstance();
    } catch (Exception $e) {
        error_log("Redis Error: " . $e->getMessage());
        $GLOBALS["redis"] = null;
    }
}
