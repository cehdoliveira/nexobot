# ============================================================================
# .ENV - CONFIGURAÇÕES DE AMBIENTE
# ============================================================================
# Este arquivo contém todas as configurações sensíveis da aplicação.
# NÃO VERSIONE ESTE ARQUIVO (está no .gitignore).
# 
# Copie este arquivo para .env.local em ambientes diferentes:
#   - .env (padrão local)
#   - .env.production (produção)
#   - .env.staging (staging)
#
# Acesse as variáveis em seu código via getenv('KEY') ou $_ENV['KEY']
# ============================================================================

# ============================================================================
# CONFIGURAÇÕES DE AMBIENTE E DEBUG
# ============================================================================
APP_ENV=local
APP_DEBUG=true
APP_NAME=NexoBot
APP_KEY=nexobot_site_session
APP_URL=http://nexobot.local

# ============================================================================
# BANCO DE DADOS (MySQL 8.0)
# ============================================================================
DB_HOST=172.29.0.2
DB_PORT=3306
DB_NAME=mysql_nexobot
DB_USER=user_nexobot
DB_PASS=@Sa131822
DB_CHARSET=utf8mb4

# ============================================================================
# REDIS (Cache)
# ============================================================================
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
REDIS_PREFIX=nexobot:site:
REDIS_DEFAULT_TTL=3600

# ============================================================================
# KAFKA (Message Queue)
# ============================================================================
KAFKA_ENABLED=true
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_TOPIC_EMAIL=nexobot_site_emails
KAFKA_CONSUMER_GROUP=nexobot-email-worker-group

# ============================================================================
# EMAIL (SMTP)
# ============================================================================
MAIL_FROM_NAME=NexoBot
MAIL_FROM_EMAIL=noreply@nexobot.local
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu-email@gmail.com
MAIL_PASS=sua-senha-app
MAIL_ENCRYPTION=tls

# ============================================================================
# SESSÃO
# ============================================================================
SESSION_LIFETIME=7200
SESSION_USE_REDIS=false
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================================================
# UPLOAD DE ARQUIVOS
# ============================================================================
UPLOAD_DIR=/var/www/nexobot/site/public_html/assets/upload/
UPLOAD_MAX_SIZE=10
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# ============================================================================
# INTEGRAÇÕES EXTERNAS
# ============================================================================
# Binance API (se utilizar)
BINANCE_ENABLED=false
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ============================================================================
# LOGS
# ============================================================================
LOG_DIR=/var/log/
LOG_LEVEL=debug
LOG_CHANNEL=single

# ============================================================================
# PAGINAÇÃO
# ============================================================================
PAGINATE_PER_PAGE=150

# ============================================================================
# CAMINHOS (Calculados automaticamente, deixe em branco para auto-detect)
# ============================================================================
APP_ROOT=/
ROOT_SERVER=
ROOT_SERVER_APP=
FRONTEND_URL=
ASSETS_URL=
