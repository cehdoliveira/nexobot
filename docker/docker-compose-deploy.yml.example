services:
  # ============================================
  # 📦 PHP Application Server (Driftex App)
  # ============================================
  app:
    image: <SUA_IMAGEM_CUSTOMIZADA>  # Ex.: driftex:latest
    environment:
      - ENABLE_CRON=true
    deploy:
      replicas: 1
      restart_policy:
        condition: any
        delay: 5s
        max_attempts: 3
      update_config:
        parallelism: 1
        delay: 10s
        order: start-first
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M
      labels:
        - "traefik.enable=true"
        - "traefik.docker.network=<SUA_REDE_INTERNET_DO_PORTAINER>"
        - "traefik.http.routers.<NOME_APP>-site.rule=Host(`<SEU_DOMINIO>`)"
        - "traefik.http.routers.<NOME_APP>-site.entrypoints=websecure"
        - "traefik.http.routers.<NOME_APP>-site.tls.certresolver=letsencryptresolver"
        - "traefik.http.routers.<NOME_APP>-site.service=<NOME_APP>-site"
        - "traefik.http.services.<NOME_APP>-site.loadbalancer.server.port=80"

    volumes:
      - /opt/<NOME_APP>/site:/var/www/<NOME_APP>/site:rw
      - /opt/<NOME_APP>/migrations:/var/www/<NOME_APP>/migrations:rw
      - /opt/<NOME_APP>/logs:/var/log:rw
      - /opt/<NOME_APP>:/git:rw

    networks:
      - <SUA_REDE_INTERNET_DO_PORTAINER>

    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  # ========================================
  # Redis Cache
  # ========================================
  redis:
    image: redis:7-alpine
    deploy:
      replicas: 1
      restart_policy:
        condition: any
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

    command: redis-server --appendonly yes --maxmemory 128mb --maxmemory-policy allkeys-lru

    volumes:
      - redis-data:/data

    networks:
      - <SUA_REDE_INTERNET_DO_PORTAINER>

    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3

  # ========================================
  # 👷 Email Worker Site (Kafka Consumer)
  # ========================================
  email_worker_site:
    image: <SUA_IMAGEM_CUSTOMIZADA>
    environment:
      - ENABLE_CRON=false
    deploy:
      replicas: 1
      restart_policy:
        condition: any
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

    volumes:
      - /opt/<NOME_APP>/site:/var/www/<NOME_APP>/site:ro
      - /opt/<NOME_APP>/logs:/var/log:rw

    networks:
      - <SUA_REDE_INTERNET_DO_PORTAINER>

    # Mesmo entrypoint da imagem, sem cron; executa apenas o worker
    command: ["php", "/var/www/<NOME_APP>/site/cgi-bin/kafka_email_worker.php"]

    healthcheck:
      test: ["CMD-SHELL", "pgrep -f kafka_email_worker.php || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

networks:
  <SUA_REDE_INTERNET_DO_PORTAINER>:
    external: true

volumes:
  redis-data:
    driver: local
